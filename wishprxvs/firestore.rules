rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone can read user profiles (needed for public links)
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Username reservation table
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Messages — anyone can send (anonymous), only recipient can read
    match /messages/{messageId} {
      allow create: if request.resource.data.content is string
                    && request.resource.data.content.size() >= 1
                    && request.resource.data.content.size() <= 500;
      allow read:   if request.auth != null && resource.data.toUserId == request.auth.uid;
      allow update: if request.auth != null && resource.data.toUserId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.toUserId == request.auth.uid;
    }

    // Community posts
    match /posts/{postId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    // Followers (anonymous — followed user never sees who)
    match /followers/{followedUserId}/list/{followerId} {
      allow read:   if request.auth != null && request.auth.uid == followerId;
      allow create: if request.auth != null && request.auth.uid == followerId;
      allow delete: if request.auth != null && request.auth.uid == followerId;
    }

    // Q&A sessions
    match /qa_sessions/{sessionId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
    match /qa_questions/{questionId} {
      allow read:   if true;
      allow create: if true;
      allow update: if request.auth != null;
    }

    // Debates
    match /debates/{debateId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update: if true;
    }

    // Notifications
    match /notifications/{notifId} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
